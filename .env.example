# Local MariaDB/MySQL connection. Percentage-encode special characters in credentials.
DATABASE_URL="mysql://APP_USER:APP_PASSWORD@127.0.0.1:3307/vcard_wig"

# Runtime database adapter settings.
DATABASE_HOST="127.0.0.1"
DATABASE_PORT="3307"
DATABASE_USER="APP_USER"
DATABASE_PASSWORD="APP_PASSWORD"
DATABASE_NAME="vcard_wig"
DATABASE_CONNECTION_LIMIT="5"

# Public URL used by redirects and, in later phases, dynamic QR codes.
APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Initial seed. Never commit real passwords.
SEED_ADMIN_USERNAME="root"
SEED_ADMIN_NAME="Root Administrator"
SEED_ADMIN_EMAIL=""
SEED_ADMIN_PASSWORD="REPLACE_WITH_A_UNIQUE_SECRET"

# Eight-hour fixed session lifetime by default.
SESSION_TTL_HOURS="8"

# Analytics and expired sessions are removed by `npm run maintenance:cleanup`.
ANALYTICS_RETENTION_DAYS="365"
EXPIRED_SESSION_RETENTION_DAYS="30"

# Optional operational overrides. Ubuntu normally resolves these binaries from PATH.
BACKUP_DIR="./backups"
MYSQL_DUMP_BIN=""
MYSQL_CLIENT_BIN=""
RESTORE_DATABASE_NAME=""
RESTORE_ALLOW_REPLACE="false"
